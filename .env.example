# Narrative generation (optional — canned fallback without it).
# Free tier is capped at 20 requests/day; by default only the end-game
# investigation report uses Gemini (1 call/game). Set GEMINI_TAUNTS=1 to
# also generate per-level rival taunts (adds 5 calls/game).
GEMINI_API_KEY=
GEMINI_TAUNTS=

# Voice layer (optional — silent fallback without it)
ELEVENLABS_API_KEY=

# Production database (dev uses DuckDB automatically)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=FALSE_SUMMIT
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
